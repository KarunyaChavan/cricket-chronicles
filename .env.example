# sportmonks.com API Token (Server-side ONLY)
SPORTMONKS_API_TOKEN=
SPORTMONKS_BASE_URL=https://cricket.sportmonks.com/api/v2.0

# Client-side configuration (VITE_ prefix exposes to bundle)
VITE_SPORTMONKS_BASE_URL=https://cricket.sportmonks.com/api/v2.0
VITE_DEFAULT_LANGUAGE=en

# Rate Limiting (BFF server)
# Set RATE_LIMIT_ENABLED=false to disable all rate limiting (e.g., dev/testing)
RATE_LIMIT_ENABLED=true
# API proxy: max 100 requests per 15-minute window per IP
RATE_LIMIT_API_WINDOW_MS=900000
RATE_LIMIT_API_MAX=100
# General SPA routes: max 1000 requests per 15-minute window per IP
RATE_LIMIT_GENERAL_WINDOW_MS=900000
RATE_LIMIT_GENERAL_MAX=1000
